            </div>
        </section>

        <!-- 3. IDENTIFICAÇÃO DA SITUAÇÃO -->
        <section class="section section-alt">
            <div class="container">
                <h2>Identifique o Seu Caso</h2>
                <p class="section-subtitle">Qual Golpe do Pix Você Sofreu?</p>

                <div class="situation-grid">
                    <div class="situation-card urgency-max">
                        <div class="situation-badge">
                            🔴 GOLPE DO FALSO INTERMEDIÁRIO
