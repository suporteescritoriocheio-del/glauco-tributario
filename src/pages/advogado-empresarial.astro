---
import SEO from "../components/SEO.astro";
import StructuredData from "../components/StructuredData.astro";
import FormScript from "../components/FormScript.astro";
import LeadCaptureModal from "../components/LeadCaptureModal.astro";
import "../styles/advogado-empresarial.css";

const pageTitle = "Advocacia Empresarial Estratégica | Glauco Ramos Advocacia";
const pageDescription =
  "Soluções jurídicas completas para empresários: direito empresarial, societário e tributário. +30 anos de experiência. Atendimento em todo o Brasil. Consultoria gratuita.";

const WPP_BASE = "https://api.whatsapp.com/send/?phone=554391244440";
const WPP = (msg: string) => `${WPP_BASE}&text=${encodeURIComponent(msg)}`;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <SEO title={pageTitle} description={pageDescription} />
    <StructuredData />
  </head>

  <body>
    <!-- GTM noscript -->
    <noscript>
      <iframe
        src="https://www.googletagmanager.com/ns.html?id=GTM-58XT4LRL"
        height="0" width="0"
        style="display:none;visibility:hidden"></iframe>
    </noscript>

    <!-- ================================================
         1. HERO — Layout Esquerda+Direita
         ================================================ -->
    <section class="hero">
      <div class="container">
        <div class="hero-inner">

          <div class="hero-left">
            <img
              src="/img/logo-glauco-ramos.webp"
              alt="Glauco Ramos Advocacia"
              class="hero-logo"
              width="60" height="60"
              loading="eager"
            />

            <div class="hero-badge">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              +30 anos de experiência · Ex-Procurador Jurídico
            </div>

            <h1>
              Sua Empresa Está Exposta?
              <span>Proteja Seu Patrimônio com Advocacia Estratégica.</span>
            </h1>

            <p class="hero-subtitle">
              Problemas societários, fiscais ou contratuais podem custar milhões.
              Mais de 30 anos defendendo empresários em todo o Brasil com estratégia e resultado.
            </p>

            <div class="hero-ctas">
              <a
                href={WPP("Olá, gostaria de agendar uma consultoria estratégica")}
                class="btn btn-primary btn-large"
                id="hero-cta-whatsapp"
              >
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81a19.79 19.79 0 01-3.07-8.67A2 2 0 012 1h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.09 8.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
                Agendar Consulta Estratégica
              </a>
              <a href="#contato" class="btn btn-secondary" id="hero-cta-form">Ver Formulário de Contato</a>
            </div>

            <p class="hero-info">
              Consultoria gratuita &nbsp;·&nbsp; Atendimento remoto em todo o Brasil &nbsp;·&nbsp; Resposta em até 24h
            </p>
          </div>

          <div class="hero-photo-wrapper">
            <img
              src="/img/glauco-ramos-advogado.jpg"
              alt="Dr. Glauco Ramos — Advogado Empresarial"
              class="hero-photo"
              width="420"
              loading="eager"
            />
          </div>

        </div>
      </div>
    </section>

    <!-- ================================================
         2. FAIXA DE CONFIANÇA
         ================================================ -->
    <div class="trust-bar" role="complementary" aria-label="Indicadores de credibilidade">
      <div class="container">
        <div class="trust-bar-inner">
          <div class="trust-item">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            <span><strong>4.5/5</strong> no Google · 31 avaliações verificadas</span>
          </div>
          <span class="trust-sep">|</span>
          <div class="trust-item">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
            <span>OAB/PR — Inscrito e em dia</span>
          </div>
          <span class="trust-sep">|</span>
          <div class="trust-item">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
            <span>SP · Curitiba · Londrina</span>
          </div>
          <span class="trust-sep">|</span>
          <div class="trust-item">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            <span>Ex-Procurador Jurídico Municipal</span>
          </div>
        </div>
      </div>
    </div>

    <!-- ================================================
         3. MANIFESTO / IDENTIFICAÇÃO DA DOR
         ================================================ -->
    <section class="manifesto section">
      <div class="container">
        <div class="manifesto-inner">
          <h2>Um Escritório que Age como Escudo do seu Negócio</h2>
          <p>
            Enquanto o empresário foca no crescimento, riscos jurídicos silenciosos acumulam-se:
            contratos mal redigidos, obrigações tributárias negligenciadas, conflitos societários
            latentes. Cada um desses pontos cegos pode se tornar, do dia para a noite,
            uma ameaça real ao patrimônio que você levou anos para construir.
          </p>
          <p>
            O escritório Glauco Ramos Advocacia atua de forma preventiva e estratégica —
            mapeamos as vulnerabilidades antes que se tornem processos, e quando o litígio
            é inevitável, atuamos com a profundidade técnica de +30 anos de prática jurídica
            em direito empresarial, tributário e societário.
          </p>
        </div>
      </div>
    </section>

    <!-- ================================================
         4. VIDEO (Lazy Load)
         ================================================ -->
    <section class="video-section">
      <div class="container">
        <div class="video-layout">
          <div class="video-content">
            <span class="video-label">
              <svg width="10" height="10" viewBox="0 0 24 24" fill="currentColor"><polygon points="5 3 19 12 5 21 5 3"/></svg>
              Assista ao vídeo
            </span>
            <h2>Conheça Nossa Abordagem Jurídica</h2>
            <p>
              Antes de contratar, entenda como trabalhamos. Nossa metodologia combina
              <strong>estratégia preventiva</strong> com atuação ágil em contencioso —
              assim sua empresa nunca é pega de surpresa.
            </p>
            <p>
              Dr. Glauco Ramos explica como proteger o patrimônio da sua empresa,
              evitar autuações fiscais e estruturar contratos que realmente funcionam.
            </p>
            <a href={WPP("Vi o vídeo e gostaria de conversar")} class="btn btn-primary" id="video-cta">
              Falar com o Dr. Glauco
            </a>
          </div>

          <div class="video-player-wrapper" id="video-player" data-video-id="mOZtKBFkCAY" role="button" tabindex="0" aria-label="Assistir apresentação do Dr. Glauco Ramos">
            <img
              src="https://img.youtube.com/vi/mOZtKBFkCAY/maxresdefault.jpg"
              alt="Apresentação — Dr. Glauco Ramos Advocacia"
              class="video-thumbnail"
              loading="lazy"
            />
            <div class="video-play-btn">
              <div class="play-icon-circle">
                <svg viewBox="0 0 24 24"><polygon points="5 3 19 12 5 21 5 3"/></svg>
              </div>
              <span class="video-play-label">Assistir Apresentação</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ================================================
         5. ÁREAS DE ATUAÇÃO
         ================================================ -->
    <section class="services-section" id="solucoes">
      <div class="container">
        <h2 class="section-heading">Áreas de Atuação</h2>
        <p class="section-subheading">Soluções jurídicas integradas para proteger e fazer seu negócio crescer</p>

        <div class="services-grid">
          <div class="service-card">
            <svg class="service-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25"><path d="M9 12h6m-3-3v6m-7 4V5a2 2 0 012-2h10a2 2 0 012 2v14l-7-3-7 3z"/></svg>
            <h3>Consultoria Empresarial</h3>
            <p>Análise completa para identificar riscos e oportunidades jurídicas antes que se tornem problemas.</p>
          </div>

          <div class="service-card">
            <svg class="service-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/></svg>
            <h3>Direito Societário</h3>
            <p>Acordo entre sócios, entrada e saída, governança corporativa e planejamento sucessório.</p>
          </div>

          <div class="service-card">
            <svg class="service-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
            <h3>Contratos Empresariais</h3>
            <p>Elaboração, análise e negociação de contratos que protegem seus interesses e evitam litígios.</p>
          </div>

          <div class="service-card">
            <svg class="service-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/></svg>
            <h3>Planejamento Tributário</h3>
            <p>Redução legal da carga tributária e defesa em autuações fiscais com estratégias personalizadas.</p>
          </div>

          <div class="service-card">
            <svg class="service-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
            <h3>Fusões e Aquisições</h3>
            <p>Assessoria completa em M&A, due diligence e reestruturações societárias.</p>
          </div>

          <div class="service-card">
            <svg class="service-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25"><path d="M21.21 15.89A10 10 0 118 2.83"/><path d="M22 12A10 10 0 0012 2v10z"/></svg>
            <h3>Recuperação Judicial</h3>
            <p>Estratégias para superar crises financeiras e manter sua empresa operando.</p>
          </div>
        </div>

        <div class="text-center">
          <a href={WPP("Preciso de ajuda com direito empresarial")} class="btn btn-primary btn-large" id="services-cta">
            Solicitar Consultoria Gratuita
          </a>
        </div>
      </div>
    </section>

    <!-- ================================================
         6. FUNDADOR / EQUIPE
         ================================================ -->
    <section class="about section" id="sobre">
      <div class="container">
        <div class="about-inner">
          <div class="about-photo">
            <img
              src="/img/glauco-ramos-advogado.jpg"
              alt="Dr. Glauco Ramos — Advogado Empresarial"
              width="300"
              loading="lazy"
            />
            <div class="photo-caption">
              <strong>Dr. Glauco Ramos</strong>
              Ex-Procurador Jurídico · OAB/PR
            </div>
          </div>

          <div class="about-content">
            <h2 class="section-heading" style="text-align:left">Conheça Dr. Glauco Ramos</h2>
            <p>
              Advogado formado pela UEL com especializações em Direito Civil, Processual Civil e
              <strong>Direito Tributário pelo IBET</strong>. Mais de 30 anos de carreira defendendo
              empresários e empresas em suas demandas mais complexas. Longa experiência como
              Procurador Jurídico no setor público, o que confere ao escritório uma visão ímpar
              sobre obrigações tributárias e processos administrativos.
            </p>

            <ul class="about-credentials">
              <li><span class="cred-dot"></span> Especialização em Direito Tributário — IBET</li>
              <li><span class="cred-dot"></span> Ex-Procurador Jurídico do Município de Rolândia-PR</li>
              <li><span class="cred-dot"></span> Ex-Procurador da CMTU de Londrina</li>
              <li><span class="cred-dot"></span> OAB/PR — Advocacia Empresarial, Societária e Tributária</li>
              <li><span class="cred-dot"></span> Escritórios em São Paulo, Curitiba e Londrina</li>
            </ul>

            <div class="about-quote">
              <p>"Meu compromisso é transformar desafios jurídicos em oportunidades para o crescimento do seu negócio."</p>
              <cite>— Dr. Glauco Ramos</cite>
            </div>

            <a href={WPP("Gostaria de falar com Dr. Glauco Ramos")} class="btn btn-primary" id="about-cta">
              Falar com Dr. Glauco
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- ================================================
         7. DEPOIMENTOS
         ================================================ -->
    <section class="testimonials-section" id="depoimentos">
      <div class="container">
        <h2 class="section-heading">O Que Dizem Nossos Clientes</h2>

        <div class="testimonials">
          <div class="testimonial">
            <span class="testimonial-quote-mark">"</span>
            <div class="testimonial-stars">
              <svg viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              <svg viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              <svg viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              <svg viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              <svg viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            </div>
            <p class="testimonial-text">
              "Excelente! Muito competente e comprometido. Mesmo sendo de outro estado, me prestou esclarecimentos do início ao fim. Fiquei muito satisfeita. Recomendo."
            </p>
            <p class="testimonial-author">— Cíntia Santos · agosto de 2024</p>
          </div>

          <div class="testimonial">
            <span class="testimonial-quote-mark">"</span>
            <div class="testimonial-stars">
              <svg viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              <svg viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              <svg viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              <svg viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              <svg viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            </div>
            <p class="testimonial-text">
              "Ética e comprometimento. Demonstrou segurança e teve soluções inovadoras. Grande especialista na área tributária."
            </p>
            <p class="testimonial-author">— Lourdes Serri · maio de 2024</p>
          </div>

          <div class="testimonial">
            <span class="testimonial-quote-mark">"</span>
            <div class="testimonial-stars">
              <svg viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              <svg viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              <svg viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              <svg viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              <svg viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            </div>
            <p class="testimonial-text">
              "Por 3 gerações fomos agraciados em ter o Dr. Glauco Ramos como patrono. Além de excelente advogado, um grande mestre e amigo."
            </p>
            <p class="testimonial-author">— Adyr Neto · maio de 2024</p>
          </div>
        </div>

        <div class="testimony-aggregate">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
          <span><strong>4.5</strong> de 5 · 31 avaliações verificadas no Google</span>
        </div>

        <div class="text-center mt-lg">
          <a href={WPP("Vi os depoimentos e gostaria de conversar")} class="btn btn-primary" id="testimonials-cta">
            Quero Resultados Como Esses
          </a>
        </div>
      </div>
    </section>

    <!-- ================================================
         8. ARTIGOS E INSIGHTS
         ================================================ -->
    <section class="articles-section" id="artigos">
      <div class="container">
        <h2 class="section-heading">Artigos e Insights Jurídicos</h2>
        <p class="section-subheading">Aprofunde seu conhecimento antes de tomar qualquer decisão</p>

        <div class="articles-grid">
          <article class="article-card">
            <div class="article-img-wrapper">
              <img
                src="/img/artigo-planejamento-tributario.webp"
                alt="Planejamento Tributário para Empresas"
                class="article-img"
                loading="lazy"
                onerror="this.parentElement.style.minHeight='180px';this.style.display='none'"
              />
              <span class="article-category">Direito Tributário</span>
            </div>
            <div class="article-body">
              <h3>Como Reduzir Legalmente a Carga Tributária da sua Empresa</h3>
              <p class="article-excerpt">Descubra as principais estratégias de planejamento tributário que empresários devem conhecer para economizar sem infringir a lei.</p>
              <a href="https://glaucoramos.com.br/guia-completo-de-planejamento-patrimonial-sucessorio-e-tributario-para-empresarios/" class="article-link" target="_blank" rel="noopener">
                Ler artigo completo →
              </a>
            </div>
          </article>

          <article class="article-card">
            <div class="article-img-wrapper">
              <img
                src="/img/artigo-contrato-empresarial.webp"
                alt="Holding Familiar para Empresários"
                class="article-img"
                loading="lazy"
                onerror="this.parentElement.style.minHeight='180px';this.style.display='none'"
              />
              <span class="article-category">Planejamento Patrimonial</span>
            </div>
            <div class="article-body">
              <h3>Holding Familiar: Guia Definitivo para Empresários</h3>
              <p class="article-excerpt">Vantagens, custos e como estruturar uma holding para proteger seu patrimônio e otimizar a sucessão empresarial.</p>
              <a href="https://glaucoramos.com.br/holding-familiar-o-guia-definitivo-para-empresarios-vantagens-custos-e-como-estruturar/" class="article-link" target="_blank" rel="noopener">
                Ler artigo completo →
              </a>
            </div>
          </article>

          <article class="article-card">
            <div class="article-img-wrapper">
              <img
                src="/img/artigo-conflito-societario.webp"
                alt="Recuperação Judicial"
                class="article-img"
                loading="lazy"
                onerror="this.parentElement.style.minHeight='180px';this.style.display='none'"
              />
              <span class="article-category">Direito Empresarial</span>
            </div>
            <div class="article-body">
              <h3>Recuperação Judicial: O Guia Definitivo para Salvar sua Empresa</h3>
              <p class="article-excerpt">Entenda quando acionar a recuperação judicial, como funciona o processo e as estratégias para preservar seu negócio em crise.</p>
              <a href="https://glaucoramos.com.br/recuperacao-judicial-o-guia-definitivo-para-salvar-sua-empresa-da-crise/" class="article-link" target="_blank" rel="noopener">
                Ler artigo completo →
              </a>
            </div>
          </article>
        </div>
      </div>
    </section>

    <!-- ================================================
         9. FAQ
         ================================================ -->
    <section class="faq-section" id="faq">
      <div class="container">
        <h2 class="section-heading">Dúvidas Frequentes</h2>

        <div class="faq-list">
          <div class="faq-item">
