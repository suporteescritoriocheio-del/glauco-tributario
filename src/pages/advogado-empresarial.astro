---
import SEO from "../components/SEO.astro";
import StructuredData from "../components/StructuredData.astro";
import FormScript from "../components/FormScript.astro";
import LeadCaptureModal from "../components/LeadCaptureModal.astro";
import "../styles/advogado-empresarial.css";

const pageTitle = "Advocacia Empresarial Estratégica | Glauco Ramos Advocacia";
const pageDescription =
  "Soluções jurídicas completas para empresários: direito empresarial, societário e tributário. +30 anos de experiência. Atendimento em todo o Brasil. Consultoria gratuita.";

const WPP_BASE = "https://api.whatsapp.com/send/?phone=554391244440";
const WPP = (msg: string) => `${WPP_BASE}&text=${encodeURIComponent(msg)}`;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <SEO title={pageTitle} description={pageDescription} />
    <StructuredData />
  </head>

  <body>
    <!-- GTM noscript -->
    <noscript>
      <iframe
        src="https://www.googletagmanager.com/ns.html?id=GTM-58XT4LRL"
        height="0" width="0"
        style="display:none;visibility:hidden"></iframe>
    </noscript>

    <!-- ================================================
         1. HERO
         ================================================ -->
    <section class="hero">
      <div class="container">
        <img
          src="/img/logo-glauco-ramos.webp"
          alt="Glauco Ramos Advocacia"
          class="hero-logo"
          width="72" height="72"
          loading="eager"
        />

        <div class="urgency-badge">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          +30 anos de experiência · Ex-Procurador Jurídico
        </div>

        <h1>
          Sua Empresa Está Exposta?
          <span>Proteja Seu Patrimônio com Advocacia Estratégica.</span>
        </h1>

        <p class="hero-subtitle">
          Problemas societários, fiscais ou contratuais podem custar milhões.
          +30 anos defendendo empresários em todo o Brasil com estratégia e resultado.
        </p>

        <div class="hero-ctas">
          <a
            href={WPP("Olá, gostaria de agendar uma consultoria gratuita")}
            class="btn btn-primary btn-large"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81a19.79 19.79 0 01-3.07-8.67A2 2 0 012 1h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.09 8.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
            Agende sua Consultoria Gratuita
          </a>
          <a href="#contato" class="btn btn-secondary">Ver Formulário de Contato</a>
        </div>

        <p class="hero-urgency">
          ✓ Consultoria gratuita &nbsp;·&nbsp; ✓ Atendimento remoto em todo o Brasil &nbsp;·&nbsp; ✓ Resposta em até 24h
        </p>

        <div class="hero-trust">
          <span class="hero-trust-item">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            4.5 · 31 avaliações Google
          </span>
          <span>·</span>
          <span class="hero-trust-item">⚖️ OAB/PR</span>
          <span>·</span>
          <span class="hero-trust-item">🏛️ Ex-Procurador Jurídico Municipal</span>
          <span>·</span>
          <span class="hero-trust-item">📍 SP · Curitiba · Londrina</span>
        </div>
      </div>
    </section>

    <!-- ================================================
         2. CREDIBILITY BAR
         ================================================ -->
    <section class="credibility">
      <div class="container">
        <div class="credibility-grid">
          <div class="credibility-item">
            <span class="credibility-icon">⭐</span>
            <div class="credibility-text">
              <strong>4.5 estrelas</strong>
              31 avaliações no Google
            </div>
          </div>
          <div class="credibility-item">
            <span class="credibility-icon">📍</span>
            <div class="credibility-text">
              <strong>3 Escritórios</strong>
              SP, Curitiba e Londrina
            </div>
          </div>
          <div class="credibility-item">
            <span class="credibility-icon">⚖️</span>
            <div class="credibility-text">
              <strong>+30 anos</strong>
              De experiência jurídica
            </div>
          </div>
          <div class="credibility-item">
            <span class="credibility-icon">🏆</span>
            <div class="credibility-text">
              <strong>Ex-Procurador</strong>
              Jurídico Municipal
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ================================================
         3. VIDEO SECTION (Lazy Load)
         ================================================ -->
    <section class="video-section section">
      <div class="container">
        <div class="video-layout">
          <div class="video-content">
            <span class="video-badge">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><polygon points="5 3 19 12 5 21 5 3"/></svg>
              Assista ao vídeo
            </span>
            <h2 class="section-heading" style="text-align:left; margin-bottom:1rem;">
              Conheça Nossa Abordagem Jurídica
            </h2>
            <p>
              Antes de acionar um advogado, entenda como trabalhamos. Nossa metodologia combina
              <strong>estratégia preventiva</strong> com atuação ágil em contencioso — assim sua
              empresa nunca é pega de surpresa.
            </p>
            <p>
              Dr. Glauco Ramos explica em detalhes como proteger o patrimônio da sua empresa,
              evitar autuações fiscais e estruturar contratos que realmente funcionam.
            </p>
            <a href={WPP("Vi o vídeo e gostaria de conversar")} class="btn btn-primary">
              Falar com o Dr. Glauco
            </a>
          </div>

          <div class="video-player-wrapper" id="video-player" data-video-id="dQw4w9WgXcQ" role="button" tabindex="0" aria-label="Assistir vídeo">
            <!-- Thumbnail (substitua pelo ID do vídeo real do YouTube) -->
            <img
              src="https://img.youtube.com/vi/dQw4w9WgXcQ/maxresdefault.jpg"
              alt="Vídeo de apresentação — Dr. Glauco Ramos"
              class="video-thumbnail"
              loading="lazy"
            />
            <div class="video-play-btn">
              <div class="play-icon-circle">
                <svg viewBox="0 0 24 24"><polygon points="5 3 19 12 5 21 5 3"/></svg>
              </div>
              <span class="video-play-label">Assistir Apresentação</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ================================================
         4. PROBLEMS
         ================================================ -->
    <section class="section problems-section section-alt">
      <div class="container">
        <h2 class="section-heading">Seu Negócio Enfrenta Algum Desses Desafios?</h2>
        <ul class="checklist">
          <li>Conflitos societários entre sócios que ameaçam a continuidade da empresa</li>
          <li>Problemas tributários com multas e autuações fiscais indevidas</li>
          <li>Contratos mal elaborados que geram prejuízos e insegurança jurídica</li>
          <li>Processos trabalhistas que comprometem o caixa da empresa</li>
          <li>Dúvidas sobre fusões e aquisições sem assessoria especializada</li>
          <li>Falta de planejamento sucessório que coloca o patrimônio em risco</li>
          <li>Disputas comerciais com fornecedores, clientes ou parceiros</li>
        </ul>
        <div class="text-center">
          <a href={WPP("Preciso de um especialista em direito empresarial")} class="btn btn-primary">
            Fale com um Especialista Agora
          </a>
        </div>
      </div>
    </section>

    <!-- ================================================
         5. SOLUTIONS
         ================================================ -->
    <section class="section">
      <div class="container">
        <h2 class="section-heading">Advocacia Empresarial Completa</h2>
        <p class="section-subheading">Soluções integradas para proteger e fazer seu negócio crescer</p>

        <div class="services-grid">
          <div class="service-card">
            <svg class="service-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 12h6m-3-3v6m-7 4V5a2 2 0 012-2h10a2 2 0 012 2v14l-7-3-7 3z"/></svg>
            <h3>Consultoria Empresarial</h3>
            <p>Análise completa para identificar riscos e oportunidades jurídicas antes que se tornem problemas.</p>
          </div>

          <div class="service-card">
            <svg class="service-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/></svg>
            <h3>Direito Societário</h3>
            <p>Acordo entre sócios, entrada e saída, governança corporativa e planejamento sucessório.</p>
          </div>

          <div class="service-card">
            <svg class="service-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
            <h3>Contratos Empresariais</h3>
            <p>Elaboração, análise e negociação de contratos que protegem seus interesses e evitam litígios.</p>
          </div>

          <div class="service-card">
            <svg class="service-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/></svg>
            <h3>Planejamento Tributário</h3>
            <p>Redução legal da carga tributária e defesa em autuações fiscais com estratégias personalizadas.</p>
          </div>

          <div class="service-card">
            <svg class="service-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
            <h3>Fusões e Aquisições</h3>
            <p>Assessoria completa em M&A, due diligence e reestruturações societárias.</p>
          </div>

          <div class="service-card">
            <svg class="service-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21.21 15.89A10 10 0 118 2.83"/><path d="M22 12A10 10 0 0012 2v10z"/></svg>
            <h3>Recuperação Judicial</h3>
            <p>Estratégias para superar crises financeiras e manter sua empresa operando.</p>
          </div>
        </div>

        <div class="text-center mt-lg">
          <a href={WPP("Preciso de ajuda com direito empresarial")} class="btn btn-primary btn-large">
            Solicite sua Consultoria Gratuita
          </a>
        </div>
      </div>
    </section>

    <!-- ================================================
         6. WHY CHOOSE US
         ================================================ -->
    <section class="section section-alt">
      <div class="container">
        <h2 class="section-heading">A Escolha de Empresários que Não Aceitam Improviso</h2>

        <div class="diff-grid">
          <div class="diff-item">
            <div class="diff-icon-wrapper">
              <svg class="diff-icon-img" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            </div>
            <div>
              <h3>Especialização Comprovada</h3>
              <p>Especialização em Direito Tributário pelo IBET e experiência como Procurador Jurídico Municipal. Domínio profundo do setor público e privado.</p>
            </div>
          </div>

          <div class="diff-item">
            <div class="diff-icon-wrapper">
              <svg class="diff-icon-img" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/></svg>
            </div>
            <div>
              <h3>Visão Nacional</h3>
              <p>Escritórios em SP, Curitiba e Londrina, com atendimento digital para todo o Brasil. Onde você estiver, estamos prontos.</p>
            </div>
          </div>

          <div class="diff-item">
            <div class="diff-icon-wrapper">
              <svg class="diff-icon-img" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
            </div>
            <div>
              <h3>Resposta Rápida 24h</h3>
              <p>Plantão 24h e primeira resposta em até 24 horas. Seu problema empresarial não pode esperar — e nós entendemos isso.</p>
            </div>
          </div>

          <div class="diff-item">
            <div class="diff-icon-wrapper">
              <svg class="diff-icon-img" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/></svg>
            </div>
            <div>
              <h3>Atendimento Personalizado</h3>
              <p>Você não é mais um número. Acesso direto a advogados sênior com conhecimento profundo do seu negócio.</p>
            </div>
          </div>
        </div>

        <div class="text-center mt-lg">
          <a href={WPP("Quero falar com um especialista em advocacia empresarial")} class="btn btn-primary">
            Agende uma Conversa
          </a>
        </div>
      </div>
    </section>

    <!-- ================================================
         7. TESTIMONIALS + SOCIAL PROOF
         ================================================ -->
    <section class="section">
      <div class="container">
        <h2 class="section-heading">O Que Dizem Empresários que Confiaram em Nós</h2>

        <div class="testimonials">
          <div class="testimonial">
            <div class="testimonial-stars">⭐⭐⭐⭐⭐</div>
            <p class="testimonial-text">
              "Excelente! Muito competente e comprometido. Mesmo sendo de outro estado, me prestou esclarecimentos do início ao fim. Fiquei muito satisfeita."
            </p>
            <p class="testimonial-author">— Cíntia Santos</p>
          </div>

          <div class="testimonial">
            <div class="testimonial-stars">⭐⭐⭐⭐⭐</div>
            <p class="testimonial-text">
              "Ética e comprometimento. Demonstrou segurança e teve soluções inovadoras. Grande especialista na área tributária."
            </p>
            <p class="testimonial-author">— Lourdes Serri</p>
          </div>

          <div class="testimonial">
            <div class="testimonial-stars">⭐⭐⭐⭐⭐</div>
            <p class="testimonial-text">
              "Por 3 gerações fomos agraciados em ter o Dr. Glauco Ramos como patrono. Além de excelente advogado, um grande mestre e amigo."
            </p>
            <p class="testimonial-author">— Adyr Neto</p>
          </div>
        </div>

        <div class="text-center mt-lg">
          <p class="social-proof-row">
            <span>⭐ <strong style="color:#fff">4.5</strong> no Google</span>
            <span>·</span>
            <span>31 avaliações verificadas</span>
          </p>
          <a
            href={WPP("Vi os depoimentos e gostaria de conversar")}
            class="btn btn-primary"
            style="margin-top:1.5rem"
          >
            Quero Resultados Como Esses
          </a>
        </div>
      </div>
    </section>

    <!-- ================================================
         8. PROCESS
         ================================================ -->
    <section class="section section-alt">
      <div class="container">
        <h2 class="section-heading">Do Primeiro Contato à Solução</h2>

        <div class="timeline">
          <div class="timeline-item">
            <div class="timeline-number">1</div>
            <div class="timeline-content">
              <h3>Contato Inicial</h3>
              <p>Entre em contato por WhatsApp, telefone ou formulário. Respondemos em até 24h para agendar sua consultoria gratuita.</p>
            </div>
          </div>
          <div class="timeline-item">
            <div class="timeline-number">2</div>
            <div class="timeline-content">
              <h3>Análise Estratégica</h3>
              <p>Reunião presencial ou online para entender profundamente seu caso e identificar a melhor estratégia jurídica.</p>
            </div>
          </div>
          <div class="timeline-item">
            <div class="timeline-number">3</div>
            <div class="timeline-content">
              <h3>Proposta Transparente</h3>
              <p>Plano de ação claro, com prazos, valores e expectativas realistas. Sem surpresas.</p>
            </div>
          </div>
          <div class="timeline-item">
            <div class="timeline-number">4</div>
            <div class="timeline-content">
              <h3>Execução e Acompanhamento</h3>
              <p>Estratégia em prática com comunicação constante. Você sempre saberá o status do seu caso.</p>
            </div>
          </div>
        </div>

        <div class="text-center mt-lg">
          <a href={WPP("Gostaria de iniciar o processo")} class="btn btn-primary">Comece Agora</a>
        </div>
      </div>
    </section>

    <!-- ================================================
         9. ABOUT
         ================================================ -->
    <section class="section about" id="sobre">
      <div class="container">
        <div class="about-inner">
          <div class="about-photo">
            <img
              src="/img/glauco-ramos-advogado.jpg"
              alt="Dr. Glauco Ramos — Advogado Empresarial"
              width="280"
              loading="lazy"
            />
            <div class="photo-caption">
              <strong>Dr. Glauco Ramos</strong>
              Ex-Procurador Jurídico · OAB/PR
            </div>
          </div>

          <div class="about-content">
            <h2 class="section-heading">Conheça Dr. Glauco Ramos</h2>
            <p>
              Advogado formado pela UEL com especializações em Direito Civil, Processual Civil e
              <strong>Direito Tributário pelo IBET</strong>. Mais de 30 anos de carreira defendendo
              empresários e empresas em suas demandas mais complexas.
            </p>

            <ul class="about-credentials">
              <li><span class="cred-icon">🎓</span> Especialização em Direito Tributário — IBET</li>
              <li><span class="cred-icon">🏛️</span> Ex-Procurador Jurídico do Município de Rolândia-PR</li>
              <li><span class="cred-icon">🏛️</span> Ex-Procurador da CMTU de Londrina</li>
              <li><span class="cred-icon">⚖️</span> OAB/PR — Advocacia Empresarial, Societária e Tributária</li>
              <li><span class="cred-icon">📍</span> Escritórios em São Paulo, Curitiba e Londrina</li>
            </ul>

            <div class="about-quote">
              <p>"Meu compromisso é transformar desafios jurídicos em oportunidades para o crescimento do seu negócio."</p>
              <cite>— Dr. Glauco Ramos</cite>
            </div>

            <a href={WPP("Gostaria de falar com Dr. Glauco Ramos")} class="btn btn-primary">
              Fale com Dr. Glauco
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- ================================================
         10. ARTICLES
         ================================================ -->
    <section class="section articles-section" id="artigos">
      <div class="container">
        <h2 class="section-heading">Conteúdo Jurídico para Empresários</h2>
        <p class="section-subheading">Aprofunde seu conhecimento antes de tomar qualquer decisão</p>

        <div class="articles-grid">
          <article class="article-card">
            <div class="article-img-wrapper">
              <img
                src="/img/artigo-planejamento-tributario.webp"
                alt="Planejamento Tributário para Empresas"
                class="article-img"
                loading="lazy"
                onerror="this.style.background='#1C2541';this.style.minHeight='180px'"
              />
              <span class="article-category">Direito Tributário</span>
            </div>
            <div class="article-body">
              <h3>Como Reduzir Legalmente a Carga Tributária da sua Empresa</h3>
              <p class="article-excerpt">Descubra as principais estratégias de planejamento tributário que empresários devem conhecer para economizar sem infringir a lei.</p>
              <a href={WPP("Vi o artigo sobre planejamento tributário e quero saber mais")} class="article-link">
                Conversar com especialista →
              </a>
            </div>
          </article>

          <article class="article-card">
            <div class="article-img-wrapper">
              <img
                src="/img/artigo-contrato-empresarial.webp"
                alt="Contratos Empresariais"
                class="article-img"
                loading="lazy"
                onerror="this.style.background='#1C2541';this.style.minHeight='180px'"
              />
              <span class="article-category">Contratos</span>
            </div>
            <div class="article-body">
              <h3>5 Cláusulas Essenciais que Todo Contrato Empresarial Precisa Ter</h3>
              <p class="article-excerpt">Saiba quais cláusulas protegem sua empresa de litígios onerosos e como revisar os contratos que você já possui.</p>
              <a href={WPP("Vi o artigo sobre contratos empresariais e quero saber mais")} class="article-link">
                Conversar com especialista →
              </a>
            </div>
          </article>

          <article class="article-card">
            <div class="article-img-wrapper">
              <img
                src="/img/artigo-conflito-societario.webp"
                alt="Conflito Societário"
                class="article-img"
                loading="lazy"
                onerror="this.style.background='#1C2541';this.style.minHeight='180px'"
              />
              <span class="article-category">Direito Societário</span>
            </div>
            <div class="article-body">
              <h3>Conflito Entre Sócios: Como Resolver Sem Destruir a Empresa</h3>
              <p class="article-excerpt">Entenda quando acionar a dissolução parcial, mediação ou arbitragem para preservar o negócio em disputas societárias.</p>
              <a href={WPP("Vi o artigo sobre conflito societário e quero saber mais")} class="article-link">
                Conversar com especialista →
              </a>
            </div>
          </article>
        </div>
      </div>
    </section>

    <!-- ================================================
         11. FAQ
         ================================================ -->
