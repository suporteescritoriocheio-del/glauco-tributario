    <script>
      // ── Video Lazy Load ───────────────────────────────
      const videoPlayer = document.getElementById('video-player') as HTMLElement | null;
      if (videoPlayer) {
        const loadVideo = () => {
          const videoId = videoPlayer.dataset.videoId;
          const iframe = document.createElement('iframe');
          iframe.src = `https://www.youtube.com/embed/${videoId}?autoplay=1&rel=0&modestbranding=1`;
          iframe.allow = 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture';
          iframe.allowFullscreen = true;
          const thumb = videoPlayer.querySelector('.video-thumbnail') as HTMLElement | null;
          const playBtn = videoPlayer.querySelector('.video-play-btn') as HTMLElement | null;
          if (thumb) thumb.style.display = 'none';
          if (playBtn) playBtn.style.display = 'none';
          videoPlayer.appendChild(iframe);
        };
        videoPlayer.addEventListener('click', loadVideo);
        videoPlayer.addEventListener('keydown', (e: KeyboardEvent) => {
          if (e.key === 'Enter' || e.key === ' ') loadVideo();
        });
      }

      // ── FAQ Accordion ─────────────────────────────────
      const faqButtons = document.querySelectorAll<HTMLButtonElement>('.faq-question');
      faqButtons.forEach(btn => {
        btn.addEventListener('click', () => {
          const item = btn.closest('.faq-item') as HTMLElement | null;
          if (!item) return;
          const isOpen = item.classList.contains('open');
          document.querySelectorAll('.faq-item').forEach(i => {
            i.classList.remove('open');
            const q = i.querySelector('.faq-question') as HTMLButtonElement | null;
            if (q) q.setAttribute('aria-expanded', 'false');
          });
          if (!isOpen) {
            item.classList.add('open');
            btn.setAttribute('aria-expanded', 'true');
          }
        });
      });
    </script>

