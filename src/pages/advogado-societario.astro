---
import SEO from "../components/SEO.astro";
import StructuredData from "../components/StructuredData.astro";
import FormScript from "../components/FormScript.astro";
import LeadCaptureModal from "../components/LeadCaptureModal.astro";
import HeroSection from "../components/HeroSection.astro";
import StickyCtaBar from "../components/StickyCtaBar.astro";
import "../styles/advogado-societario.css";

const pageTitle = "Advogado Societário | Resolução de Conflitos e Proteção | Glauco Ramos";
const pageDescription =
  "Escritório especialista em Direito Societário. Atuamos com Acordo de Sócios, Dissolução de Sociedade, M&A e Holding. +30 anos de experiência em prol do seu negócio.";

const WPP_BASE = "https://api.whatsapp.com/send/?phone=554391244440&text=Ol%C3%A1%2C%20gostaria%20de%20falar%20com%20um%20especialista";
const WPP = (_msg: string) => "https://api.whatsapp.com/send/?phone=554391244440&text=Ol%C3%A1%2C%20gostaria%20de%20falar%20com%20um%20especialista";

const heroProps = {
  content: {
    badgeText: "Advogado Societário · Atendimento Nacional",
    title: "Proteção do Seu Patrimônio e Resolução de Conflitos entre ",
    titleHighlight: "Sócios da Sua Empresa.",
    subtitle: "A falta de estruturação societária correta pode custar o seu negócio. Evite bloqueios, exclusões injustas e litígios destrutivos com nossa experiência de mais de 30 anos defendendo interesses corporativos.",
    primaryCtaLabel: "Agendar Consulta Estratégica",
    infoItems: [
      "Consultoria gratuita",
      "Atendimento remoto em todo o Brasil",
      "Primeira resposta rápida"
    ]
  },
  logo: {
    src: "/img/logo-glauco-ramos.webp",
    alt: "Glauco Ramos Advocacia",
    width: 60,
    height: 60,
    loading: "eager" as const
  },
  image: {
    src: "/img/glauco-ramos-advogado.jpg",
    alt: "Dr. Glauco Ramos — Advogado Societário",
    width: 420,
    loading: "eager" as const
  },
  primaryCtaHref: WPP("Olá, preciso de um Advogado Societário urgente para minha empresa"),
  primaryCtaId: "hero-cta-whatsapp",
  primaryCtaDataMessage: "Olá, preciso de um Advogado Societário urgente para minha empresa"
};

const stickyCtaProps = {
  ariaLabel: "Barra de contato rápido da landing page de advogado societário",
  title: "Fale com o Societário",
  subtitle: "Orientação rápida para conflitos e blindagem da sociedade",
  ctas: [
    {
      href: WPP("Desejo orientações diretas sobre meu negócio"),
      label: "WhatsApp",
      variant: "whatsapp" as const,
      icon: "whatsapp" as const,
      id: "sticky-whatsapp",
      dataMessage: "Olá, gostaria de falar com um especialista",
      ariaLabel: "Falar via WhatsApp sobre direito societário",
    },
  ],
};
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <SEO title={pageTitle} description={pageDescription} />
    <StructuredData />
  </head>

  <body>
    <!-- GTM noscript -->
    <noscript>
      <iframe
        src="https://www.googletagmanager.com/ns.html?id=GTM-58XT4LRL"
        height="0" width="0"
        style="display:none;visibility:hidden"></iframe>
    </noscript>

    <!-- ================================================
         1. HERO — Layout Esquerda+Direita
         ================================================ -->
    <HeroSection {...heroProps} />

    <!-- ================================================
         2. FAIXA DE CONFIANÇA
         ================================================ -->
    <div class="trust-bar" role="complementary" aria-label="Indicadores de credibilidade">
      <div class="container">
        <div class="trust-bar-inner">
          <div class="trust-item">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            <span><strong>4.5/5</strong> no Google · 31 avaliações verificadas</span>
          </div>
          <span class="trust-sep">|</span>
          <div class="trust-item">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
            <span>OAB/PR — Inscrito e em dia</span>
          </div>
          <span class="trust-sep">|</span>
          <div class="trust-item">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
            <span>Atendimento Digital para Todo Brasil</span>
          </div>
          <span class="trust-sep">|</span>
          <div class="trust-item">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            <span>Consultoria Preventiva e Contencioso</span>
          </div>
        </div>
      </div>
    </div>

    <!-- ================================================
         3. MANIFESTO / IDENTIFICAÇÃO DA DOR
         ================================================ -->
    <section class="manifesto section">
      <div class="container">
        <div class="manifesto-inner">
          <h2>Um Escritório Especializado como Escudo do seu Negócio</h2>
          <p>
            O Direito Societário exige visão além da lei. Quando os sócios não possuem 
            um Acordo blindado e sob medida para a operação, as chances de litígios intermináveis multiplicam.
            O judiciário brasileiro possui regras rígidas na apuração de haveres e na dissolução de empresas.
          </p>
          <p>
            Muitas fortunas familiares e operações são destruídas por um movimento equivocado ou 
            contrato padrão da internet. A <strong>Glauco Ramos Advocacia</strong> previne atritos redigindo 
            contratos precisos e atuando firmemente na mediação e nos tribunais, assegurando a continuidade 
            das operações e a segurança inquestionável do seu patrimônio.
          </p>
        </div>
      </div>
    </section>

    <!-- ================================================
         4. VIDEO (Lazy Load)
         ================================================ -->
    <section class="video-section">
      <div class="container">
        <div class="video-layout">
          <div class="video-content">
            <span class="video-label">
              <svg width="10" height="10" viewBox="0 0 24 24" fill="currentColor"><polygon points="5 3 19 12 5 21 5 3"/></svg>
              Assista ao vídeo
            </span>
            <h2>Conheça Nossa Abordagem Estratégica</h2>
            <p>
              Em disputas de controle de empresas ou estruturação do patrimônio, 
              sua empresa nunca pode ser orientada por teses incertas. 
            </p>
            <p>
              O Dr. Glauco Ramos explica como atuamos para proteger o patrimônio e a sociedade da 
              sua empresa das maiores fragilidades, evitando surpresas fiscais ocultas e garantindo uma negociação segura.
            </p>
            <a href={WPP("Assisti ao seu vídeo e gostaria de orientação societária")} class="btn btn-primary" id="video-cta" data-message="Olá, gostaria de falar com um especialista">
              Falar com o Dr. Glauco
            </a>
          </div>

          <div class="video-player-wrapper" id="video-player" data-video-id="mOZtKBFkCAY" role="button" tabindex="0" aria-label="Assistir apresentação do Dr. Glauco Ramos">
            <img
              src="https://img.youtube.com/vi/mOZtKBFkCAY/maxresdefault.jpg"
              alt="Apresentação — Dr. Glauco Ramos Advocacia"
              class="video-thumbnail"
              loading="lazy"
            />
            <div class="video-play-btn">
              <div class="play-icon-circle">
                <svg viewBox="0 0 24 24"><polygon points="5 3 19 12 5 21 5 3"/></svg>
              </div>
              <span class="video-play-label">Assistir Apresentação</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ================================================
         5. ÁREAS DE ATUAÇÃO (SOCIETÁRIO)
         ================================================ -->
    <section class="services-section" id="solucoes">
      <div class="container">
        <h2 class="section-heading">Soluções em Direito Societário</h2>
        <p class="section-subheading">Do pré-conflito à consolidação corporativa, entregamos resultados precisos</p>

        <div class="services-grid">
          <div class="service-card">
            <svg class="service-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"></rect><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"></path></svg>
            <h3>Acordo de Sócios e Quotistas</h3>
            <p>Elaboração minuciosa de regras que regulam direitos, deveres, votações, tag/drag along e proteção contra a ingerência de herdeiros ou divórcios de sócios.</p>
          </div>

          <div class="service-card">
            <svg class="service-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25"><path d="M18.36 6.64a9 9 0 1 1-12.73 0"></path><line x1="12" y1="2" x2="12" y2="12"></line></svg>
            <h3>Dissolução de Sociedade</h3>
            <p>Atuação objetiva para sócios retirantes e venda de quotas, bem como em processos judiciais de exclusão de integrantes por justa causa ou desvios de conduta.</p>
          </div>

          <div class="service-card">
            <svg class="service-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25"><line x1="12" y1="1" x2="12" y2="23"></line><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path></svg>
            <h3>Apuração de Haveres</h3>
            <p>Estratégia e cálculo minucioso sobre o verdadeiro Valuation da empresa no momento do desligamento do membro da sociedade, evitando um enriquecimento sem causa.</p>
          </div>

          <div class="service-card">
            <svg class="service-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25"><circle cx="18" cy="5" r="3"></circle><circle cx="6" cy="12" r="3"></circle><circle cx="18" cy="19" r="3"></circle><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"></line><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"></line></svg>
            <h3>Fusões e Aquisições (M&A)</h3>
            <p>Extensa auditoria legal (Due Diligence societária, fiscal e penal). Criação de contratos de compra e venda assegurando tranquilidade contra passivos trabalhistas e fiscais.</p>
          </div>

          <div class="service-card">
            <svg class="service-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg>
            <h3>Holding e Sucessão</h3>
            <p>Instituição e reestruturação de Holdings no contexto de blindagem do patrimônio, facilitando a partilha para a sucessão enquanto garante reduções drásticas de multas do inventário.</p>
          </div>

          <div class="service-card">
            <svg class="service-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
            <h3>Defesa e Responsabilidade</h3>
            <p>Blindagem e acompanhamento preventivo em reuniões e assembleias, além da forte defesa do empresário perante os órgãos contra a temida Desconsideração da Personalidade Jurídica.</p>
          </div>
        </div>

        <div class="highlight-box text-center">
            <p>
              <strong>O Nosso Diferencial (Societário + Tributário):</strong> Decisões societárias afetam gravemente a apuração de impostos e encargos. O Dr. Glauco Ramos possui a expertise tributária aliada ao conhecimento corporativo avançado, gerando economia fiscal.
            </p>
        </div>

        <div class="text-center mt-lg">
          <a href={WPP("Gostaria de uma análise do meu cenário societário")} class="btn btn-primary btn-large" id="services-cta" data-message="Olá, gostaria de falar com um especialista">
            Requerer Análise Especializada
          </a>
        </div>
      </div>
    </section>

    <!-- ================================================
         6. FUNDADOR / EQUIPE
         ================================================ -->
    <section class="about section" id="sobre">
      <div class="container">
        <div class="about-inner">
          <div class="about-photo">
            <img
              src="/img/glauco-ramos-advogado.jpg"
              alt="Dr. Glauco Ramos — Advogado Societário"
              width="300"
              loading="lazy"
            />
            <div class="photo-caption">
              <strong>Dr. Glauco Ramos</strong>
              Ex-Procurador Jurídico · OAB/PR
            </div>
          </div>

          <div class="about-content">
            <h2 class="section-heading" style="text-align:left">Estratégia Integral e Alinhamento Superior</h2>
            <p>
              Formado pela UEL e dono de uma notável trajetória ao longo dos seus mais de 30 anos no Direito, Dr. Glauco alia o 
              conhecimento prático da Advocacia Corporativa à sua expertise como <strong>Especialista em Direito Tributário pelo IBET</strong> 
              (Instituto Brasileiro de Direito Tributário).
            </p>
            <p>
              O verdadeiro advogado societário deve dominar a gestão civil da empresa, sem esquecer dos abalos de herança e do 
              fisco. O nosso escritório já instituiu e reordenou corporações agindo com contínua eficiência, preservando fortunas e resolvendo 
              inúmeros conflitos entre diretores.
            </p>

            <ul class="about-credentials">
              <li><span class="cred-dot"></span> Ex-Procurador Jurídico municipal lidando com teses administrativas e preventivas</li>
              <li><span class="cred-dot"></span> Extensiva expertise na esfera Contenciosa (judicial e extrajudicial)</li>
              <li><span class="cred-dot"></span> Atuação discreta, altamente alinhada com os reais interesses de controle do cliente</li>
              <li><span class="cred-dot"></span> Atendimentos via escritórios físicos e bancas digitais em todos os estados brasileiros</li>
            </ul>

            <div class="about-quote">
              <p>"Proteger o capital da sua empresa e mediar soluções definitivas não é apenas questão de contrato; é estratégia com inteligência tributária e civil integrada."</p>
              <cite>— Dr. Glauco Ramos</cite>
            </div>

            <a href={WPP("Desejo falar com o Dr. Glauco Ramos agora")} class="btn btn-primary" id="about-cta" data-message="Olá, gostaria de falar com um especialista">
              Falar com o Dr. Glauco
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- ================================================
         7. DEPOIMENTOS
         ================================================ -->
    <section class="testimonials-section" id="depoimentos">
      <div class="container">
        <h2 class="section-heading">Avaliações das Nossas Atuações</h2>

        <div class="testimonials">
          <div class="testimonial">
            <span class="testimonial-quote-mark">"</span>
            <div class="testimonial-stars">
              <svg viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              <svg viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              <svg viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              <svg viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              <svg viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            </div>
            <p class="testimonial-text">
              "Atendimento excelente. Ética e comprometimento. Demonstrou segurança e teve soluções inovadoras. Grande especialista em sua área."
            </p>
            <p class="testimonial-author">— Lourdes Serri · Avaliação Google</p>
          </div>

          <div class="testimonial">
            <span class="testimonial-quote-mark">"</span>
            <div class="testimonial-stars">
              <svg viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              <svg viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              <svg viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              <svg viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              <svg viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            </div>
            <p class="testimonial-text">
              "Por 3 gerações fomos agraciados em ter como patrono em nossas causas judiciais o Dr. Glauco Ramos, que movido a excelência nos representou bravamente."
            </p>
            <p class="testimonial-author">— Adyr Neto · Avaliação Google</p>
          </div>

          <div class="testimonial">
            <span class="testimonial-quote-mark">"</span>
            <div class="testimonial-stars">
              <svg viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              <svg viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              <svg viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              <svg viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              <svg viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            </div>
            <p class="testimonial-text">
              "Excelente! Me prestou esclarecimentos sobre o processo do início ao fim mesmo estando em outro estado. Fiquei muito satisfeita. Recomendo."
            </p>
            <p class="testimonial-author">— Cíntia Santos · Avaliação Google</p>
          </div>
        </div>

        <div class="testimony-aggregate">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
          <span><strong>4.5</strong> de 5 · 31 avaliações verificadas no Google</span>
        </div>

        <div class="text-center mt-lg">
          <a href={WPP("Vi a expertise do escritório e gostaria de conversar")} class="btn btn-primary" id="testimonials-cta" data-message="Olá, gostaria de falar com um especialista">
            Proteger os Interesses da Sua Empresa
          </a>
        </div>
      </div>
    </section>

    <!-- ================================================
         8. ARTIGOS E INSIGHTS
         ================================================ -->
    <section class="articles-section" id="artigos">
      <div class="container">
        <h2 class="section-heading">Artigos e Insights Corporativos</h2>
        <p class="section-subheading">Aprofunde seu conhecimento antes de tomar atitudes irrevogáveis na sociedade.</p>

        <div class="articles-grid">
          <article class="article-card">
            <div class="article-img-wrapper">
              <img
                src="/img/artigo-planejamento-tributario.webp"
                alt="Planejamento Tributário"
                class="article-img"
                loading="lazy"
                onerror="this.parentElement.style.minHeight='180px';this.style.display='none'"
              />
              <span class="article-category">Direito Tributário e Gestão</span>
            </div>
            <div class="article-body">
              <h3>Como Reduzir Legalmente as Perdas com a Carga Tributária</h3>
              <p class="article-excerpt">Nos atritos societários, ignorar o arranjo dos impostos e transações significa expor a empresa à ruína no repasse de lucros e haveres.</p>
              <a href="https://glaucoramos.com.br/guia-completo-de-planejamento-patrimonial-sucessorio-e-tributario-para-empresarios/" class="article-link" target="_blank" rel="noopener">
                Ler artigo completo →
              </a>
            </div>
          </article>

          <article class="article-card">
            <div class="article-img-wrapper">
              <img
                src="/img/artigo-contrato-empresarial.webp"
                alt="Blindagem Patrimonial via Holding Familiar"
                class="article-img"
                loading="lazy"
                onerror="this.parentElement.style.minHeight='180px';this.style.display='none'"
              />
              <span class="article-category">Holding Patrimonial</span>
            </div>
            <div class="article-body">
              <h3>Holding Familiar: Guia Prático na Visão do Sócio</h3>
              <p class="article-excerpt">As vantagens diretas de organizar o seu controle familiar protegendo empresas, os custos reais e as armadilhas fáceis a que herdeiros são submetidos.</p>
              <a href="https://glaucoramos.com.br/holding-familiar-o-guia-definitivo-para-empresarios-vantagens-custos-e-como-estruturar/" class="article-link" target="_blank" rel="noopener">
                Ler artigo completo →
              </a>
            </div>
          </article>

          <article class="article-card">
            <div class="article-img-wrapper">
              <img
