                        </svg>
                        <h3>Uso Inadequado de Recursos</h3>
                        <p>
                            Uso indevido de bens públicos, patrimônio ou
                            sistemas
                        </p>
                    </div>
                </div>

                <div class="spheres-list">
                    <h4>Atenção especial para:</h4>
                    <div class="spheres-grid">
                        <span>✓ Servidores Municipais</span>
