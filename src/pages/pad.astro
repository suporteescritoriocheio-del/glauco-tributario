        <!-- 8. EXPERIÊNCIA COMPROVADA -->
        <section class="section about section-dark">
            <div class="container">
                <h2>Quem Defende Você Conhece o Sistema Por Dentro</h2>

                <div class="about-grid">
                    <div class="about-photo">
                        <img src="/img/glauco-ramos-advogado.jpg" alt="Dr. Glauco Ramos — Advogado" width="280" />
                        <div class="photo-caption">
                            <strong>Dr. Glauco Ramos</strong>
                            Ex-Procurador Jurídico • OAB/PR
                        </div>
                    </div>
                    <div class="about-content">
                        <h3>Dr. Glauco Ramos - Formação e Trajetória</h3>
                        <ul class="credentials-list">
                            <li>
                                ✓ Advogado pela UEL - Universidade Estadual de
                                Londrina
