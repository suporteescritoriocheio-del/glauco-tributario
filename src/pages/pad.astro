                        data-message="Quero defesa especializada em PAD">FALAR COM ESPECIALISTA</a
                    >
                </div>
            </div>
        </section>

        <!-- 6. METODOLOGIA DE DEFESA -->
        <section class="section section-alt">
            <div class="container">
                <h2>Nossa Metodologia de Defesa em PAD</h2>
                <p class="section-subtitle">Estratégia em Cada Etapa</p>

                <div class="timeline">
                    <div class="timeline-item">
                        <div class="timeline-number">1</div>
                        <div class="timeline-content">
                            <h3>ANÁLISE TÉCNICA EMERGENCIAL (24-48h)</h3>
                            <p>
                                Análise completa da notificação, identificação
                                dos fatos imputados, tipificação da
                                irregularidade e levantamento de prazos fatais.
                            </p>
                        </div>
                    </div>

                    <div class="timeline-item">
                        <div class="timeline-number">2</div>
                        <div class="timeline-content">
                            <h3>ESTRATÉGIA DEFENSIVA PERSONALIZADA</h3>
                            <p>
                                Identificação das teses de defesa aplicáveis,
                                análise de jurisprudência administrativa e
                                judicial, e planejamento das provas necessárias.
                            </p>
                        </div>
                    </div>

                    <div class="timeline-item">
                        <div class="timeline-number">3</div>
                        <div class="timeline-content">
                            <h3>DEFESA PRÉVIA TÉCNICA</h3>
                            <p>
                                Elaboração de defesa robusta com fundamentação
                                jurídica específica, contestação pontual de cada
                                imputação e juntada de documentos
                                comprobatórios.
                            </p>
                        </div>
                    </div>

                    <div class="timeline-item">
                        <div class="timeline-number">4</div>
                        <div class="timeline-content">
                            <h3>ACOMPANHAMENTO DA INSTRUÇÃO</h3>
                            <p>
                                Acompanhamento de oitivas, indicação e
                                inquirição de testemunhas estratégicas,
                                contestação de provas da acusação e juntada de
                                novas provas.
                            </p>
                        </div>
                    </div>

                    <div class="timeline-item">
                        <div class="timeline-number">5</div>
                        <div class="timeline-content">
                            <h3>ALEGAÇÕES FINAIS CONCLUSIVAS</h3>
                            <p>
                                Síntese técnica de toda a defesa, análise
                                crítica das provas produzidas, demonstração de
                                nulidades (se houver) e pedido fundamentado.
                            </p>
                        </div>
                    </div>

                    <div class="timeline-item">
                        <div class="timeline-number">6</div>
                        <div class="timeline-content">
                            <h3>RECURSO E JUDICIALIZAÇÃO</h3>
                            <p>
                                Se necessário: recurso administrativo
                                hierárquico, mandado de segurança
                                preventivo/repressivo ou ação anulatória.
                            </p>
                        </div>
                    </div>
                </div>

                <div class="info-box">
                    <p>
                        💼 <strong>Você não fica sozinho:</strong> Mantemos comunicação
                        constante via WhatsApp, com atualizações sobre cada etapa
                        e orientações sobre como proceder.
                    </p>
                </div>

                <div class="text-center mt-lg">
                    <a
                        href="https://api.whatsapp.com/send/?phone=554391244440&text=Quero%20iniciar%20minha%20defesa%20em%20PAD"
                        class="btn btn-primary"
                        data-message="Quero iniciar minha defesa em PAD">INICIAR MINHA DEFESA</a
                    >
                </div>
            </div>
        </section>

        <!-- 7. TIPOS DE PAD -->
        <section class="section">
            <div class="container">
                <h2>Defendemos Servidores em Todas as Esferas</h2>
                <p class="section-subtitle">E em Todas as Situações</p>

                <div class="services-grid">
