                            xmlns="http://www.w3.org/2000/svg"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="1.5"
                        >
                            <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"
                            ></path><circle cx="9" cy="7" r="4"></circle><path
                                d="M23 21v-2a4 4 0 00-3-3.87"></path><path
                                d="M16 3.13a4 4 0 010 7.75"></path>
                        </svg>
                        <h3>Conflitos Hierárquicos</h3>
                        <p>
                            Insubordinação, desídia, desacato a superior
                            hierárquico
                        </p>
                    </div>

                    <div class="service-card">
                        <svg
                            class="service-icon"
                            xmlns="http://www.w3.org/2000/svg"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="1.5"
                        >
                            <circle cx="12" cy="12" r="10"></circle><line
                                x1="12"
                                y1="8"
                                x2="12"
                                y2="12"></line><line
                                x1="12"
                                y1="16"
                                x2="12.01"
                                y2="16"></line>
                        </svg>
                        <h3>Questões Disciplinares</h3>
                        <p>
