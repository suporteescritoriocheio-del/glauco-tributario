---
import SEO from "../components/SEO.astro";
import "../styles/recuperacao-judicial.css";
import LeadCaptureModal from "../components/LeadCaptureModal.astro";
import FormScript from "../components/FormScript.astro";
import StickyCtaBar from "../components/StickyCtaBar.astro";

const WPP_BASE = "https://api.whatsapp.com/send/?phone=554391244440";
const WPP = (msg: string) => `${WPP_BASE}&text=${encodeURIComponent(msg)}`;

const stickyCtaProps = {
  ariaLabel: "Barra de contato rápido da landing page de recuperação judicial",
  title: "Recuperação Judicial",
  subtitle: "Avaliação sigilosa para proteger o caixa da empresa",
  ctas: [
    {
      href: WPP("Gostaria de conversar com um Advogado sobre Recuperação Judicial/Crise Bancária"),
      label: "WhatsApp",
      variant: "whatsapp" as const,
      icon: "whatsapp" as const,
      id: "sticky-whatsapp",
      dataMessage: "Gostaria de conversar com um Advogado sobre Recuperação Judicial/Crise Bancária",
      ariaLabel: "Falar via WhatsApp sobre recuperação judicial",
    },
  ],
};
---

<html lang="pt-BR">
    <head>
        <SEO
            title="Advogado Especialista em Recuperação Judicial | Evite a Falência | Glauco Ramos Advocacia"
            description="Escritório especialista em Recuperação Judicial. Suspenda cobranças (Stay Period), proteja seu patrimônio e negocie dívidas com bancos e credores com deságios."
        />
        <!-- Otimização estrutural para Google Ads (Palavra-chave: Recuperação Judicial) -->
    </head>
    <body>
        <!-- Google Tag Manager (noscript) -->
        <noscript>
            <iframe
                src="https://www.googletagmanager.com/ns.html?id=GTM-58XT4LRL"
                height="0"
                width="0"
                style="display:none;visibility:hidden"></iframe>
        </noscript>

        <!-- 1. HERO SECTION -->
        <section class="hero">
            <div class="container">
                <img src="/img/logo-glauco-ramos.webp" alt="Glauco Ramos Advocacia" class="hero-logo" width="80" height="80" />
                <div class="urgency-badge">
                    ⚖️ ADVOGADO DE RECUPERAÇÃO JUDICIAL: Proteção Legal Para CNPJs em Crise
                </div>
                <h1>
                    Recuperação Judicial: O Fôlego Definitivo Para Salvar a Sua Empresa
                </h1>
                <p class="hero-subtitle">
                    Evite a falência, suspenda as ações de cobranças imediatamente (Stay Period) e negocie toda a dívida da sua empresa em bloco, conquistando deságios (descontos) que trarão o troco e a margem de volta.
                </p>
                <a
                    href="https://api.whatsapp.com/send/?phone=554391244440&text=Olá,%20preciso%20de%20orientação%20urgente%20sobre%20Recuperação%20Judicial"
                    class="btn btn-primary btn-large"
                    data-message="Olá, preciso de orientação urgente sobre Recuperação Judicial"
                    >FALAR COM UM ESPECIALISTA EM RECUPERAÇÃO JUDICIAL</a
                >
                <p class="hero-urgency">
                    ✓ Defesa contra leilões e bloqueios | ✓ Maior Fôlego no Caixa
                </p>
                <div class="hero-trust">
                    <span>⭐⭐⭐⭐⭐ 4.5 no Google</span>
                    <span>•</span>
                    <span>OAB/PR</span>
                    <span>•</span>
                    <span>Especialistas em Crise Corporativa e Tributária</span>
                </div>
            </div>
        </section>

        <!-- 2. BARRA DE URGÊNCIA E CREDIBILIDADE -->
        <section class="urgency-bar">
            <div class="container">
                <p class="urgency-text">
                    ⚠️ MUDANÇA DE CENÁRIO: Ao deferir seu pedido de Recuperação Judicial, a Justiça suspende automaticamente as execuções e penhoras contra a sua conta bancária.
                </p>
                <div class="credibility-icons">
                    <span>⚖️ Escritório e Equipe Altamente Especializados</span>
                    <span>📊 Gestão do Endividamento Multimilionário</span>
                    <span>⭐ Retorno à Viabilidade Econômica</span>
                    <span>🇧🇷 Atendimento 100% Digital e Sigiloso no País Todo</span>
                </div>
            </div>
        </section>

        <!-- 3. IDENTIFICAÇÃO DA SITUAÇÃO -->
        <section class="section section-alt">
            <div class="container">
                <h2>A Sua Empresa Está Pronta Para a Recuperação Judicial?</h2>
                <p class="section-subtitle">
                    Identifique abaixo qual é a pressão crítica que sua operação está sofrendo hoje.
                </p>

                <div class="situation-grid">
                    <div class="situation-card urgency-max">
                        <div class="situation-badge">🔴 RISCO DE FALÊNCIA</div>
                        <h3>
                            Pedido de Falência Eminente e Contas Travadas (Bacenjud)
                        </h3>
                        <ul>
                            <li>
                                <strong>Cenário:</strong> Fornecedores ou bancos entraram na Justiça para lacrar suas portas ou bloquearam todo o faturamento da empresa.
                            </li>
                            <li>
                                <strong>Risco:</strong> Fechamento da PJ, liquidação forçada de bens e desemprego generalizado e imediato.
                            </li>
                            <li>
                                <strong>Ação:</strong> Ajuizar a Recuperação Judicial às pressas (Pedido de Tutela) para instalar a blindagem e parar as contrições.
                            </li>
                        </ul>
                        <a
                            href="https://api.whatsapp.com/send/?phone=554391244440&text=Socorro,%20estou%20sofrendo%20uma%20ação%20com%20risco%20de%20falência"
                            class="btn btn-danger"
                            data-message="Socorro, estou sofrendo uma ação com risco de falência">BLINDAGEM CONTRA FALÊNCIA AGORA</a
                        >
                    </div>

                    <div class="situation-card urgency-high">
                        <div class="situation-badge">🟡 EXECUÇÕES EM MASSA</div>
                        <h3>Múltiplas Execuções (Trabalhistas e Bancárias)</h3>
                        <ul>
                            <li>
                                <strong>Cenário:</strong> Funcionários e Bancos asfixiando os recebíveis e tentando leiloar imóveis da fábrica/loja/sede.
                            </li>
                            <li>
                                <strong>Risco:</strong> Desmonte da linha de produção (perda de máquinas ou capital de giro essencial).
                            </li>
                            <li>
                                <strong>Ação:</strong> Utilizar o "Stay Period" (prazo de carência processual de 180 dias) para respirar.
                            </li>
                        </ul>
                        <a
                            href="https://api.whatsapp.com/send/?phone=554391244440&text=Meus%20bens%20e%20caixa%20estão%20sendo%20executados,%20preciso%20de%20ajuda"
                            class="btn btn-warning"
                            data-message="Meus bens e caixa estão sendo executados, preciso de ajuda"
                            >SUSPENDER PENHORAS E LEILÕES</a
                        >
                    </div>

                    <div class="situation-card urgency-planning">
                        <div class="situation-badge">🟢 REESTRUTURAÇÃO</div>
                        <h3>Dívidas Renegociadas com 'Deságio' Gigante</h3>
                        <ul>
                            <li>
                                <strong>Cenário:</strong> A empresa fatura, mas a margem só serve para pagar juros abusivos de bancos semana a semana.
                            </li>
                            <li>
                                <strong>Risco:</strong> Ficar trabalhando de graça para o banco até chegar na inadimplência total.
                            </li>
                            <li>
                                <strong>Ação:</strong> Submeter os Bancos a um Plano de Recuperação, onde os valores sofrem grande deságio (corte) e dilatação do prazo.
                            </li>
                        </ul>
                        <a
                            href="https://api.whatsapp.com/send/?phone=554391244440&text=Quero%20entender%20como%20descontar%20dívidas%20na%20Recuperação%20Judicial"
                            class="btn btn-success"
                            data-message="Quero entender como descontar dívidas na Recuperação Judicial"
                            >ESTUDAR RENEGOCIAÇÃO GLOBAL</a
                        >
                    </div>

                    <div class="situation-card urgency-appeal">
                        <div class="situation-badge">🔵 EXTRAJUDICIAL</div>
                        <h3>Recuperação Extrajudicial (Em Acordos)</h3>
                        <ul>
                            <li>
                                <strong>Cenário:</strong> Negócio altamente viável que concorda previamente com a maioria dos credores principais (Ex: um banco chave).
                            </li>
                            <li>
                                <strong>Risco:</strong> Gastar uma fortuna e tempo excessivo com a Justiça ao em vez de um rito sumário.
                            </li>
                            <li>
                                <strong>Ação:</strong> Entrar apenas para a homologação judicial do plano previamente negociado de portas fechadas.
                            </li>
                        </ul>
                        <a
                            href="https://api.whatsapp.com/send/?phone=554391244440&text=Tenho%20interesse%20na%20Recuperação%20Extrajudicial"
                            class="btn btn-info"
                            data-message="Tenho interesse na Recuperação Extrajudicial">AVALIAR A OPÇÃO EXTRAJUDICIAL</a
                        >
                    </div>
                </div>
            </div>
        </section>

        <!-- 4. ENTENDA OS RISCOS -->
        <section class="section section-dark">
            <div class="container">
                <h2>Se Você Não Tomar As Rédeas, o Mercado Irá "Liquidar" Sua Empresa</h2>
                <p class="section-subtitle">
                    A Recuperação Judicial é um direito da empresa viável. Ignorar isso traz consequências sérias.
                </p>

                <div class="risks-grid">
                    <div class="risk-card">
                        <!-- Icon: Arrow Down Trend -->
                        <svg class="risk-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                            <polyline points="23 18 13.5 8.5 8.5 13.5 1 6"></polyline>
                            <polyline points="17 18 23 18 23 12"></polyline>
                        </svg>
                        <h3>FALÊNCIA OFICIAL DECRETADA</h3>
                        <p>
                            Credores cujo pedido atinge a cota exigida pela lei pedirão sua falência. Sendo decretada, suas chaves são recolhidas e você perde tudo sob supervisão de um síndico do Estado.
                        </p>
                    </div>

                    <div class="risk-card">
                        <!-- Icon: Shield Alert -->
                        <svg class="risk-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
                            <line x1="12" y1="8" x2="12" y2="12"></line>
                            <line x1="12" y1="16" x2="12.01" y2="16"></line>
                        </svg>
                        <h3>RESPONSABILIZAÇÃO PESSOAL</h3>
                        <p>
                            Na bagunça do endividamento descontrolado (sem Recuperador), credores conseguem facilmente a <i>Desconsideração da Personalidade Jurídica</i>, transferindo a dívida do CNPJ para o seu CPF e sua família.
                        </p>
                    </div>

                    <div class="risk-card">
                        <!-- Icon: File X -->
                        <svg class="risk-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                            <rect x="2" y="7" width="20" height="14" rx="2" ry="2"></rect>
                            <path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"></path>
                        </svg>
                        <h3>TRAVAS BANCÁRIAS</h3>
                        <p>
                            A máquina de cartão, os boletos e os recebíveis ficam "travados" diariamente pelos bancos antes de chegar no seu saldo. Sem Recuperação Judicial, e com o CND sujo, a operação congela.
                        </p>
                    </div>

                    <div class="risk-card">
                        <!-- Icon: Uses Minus -->
                        <svg class="risk-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                            <polyline points="14 2 14 8 20 8"></polyline>
                            <line x1="9" y1="15" x2="15" y2="15"></line>
                        </svg>
                        <h3>PERDA DA CONFIANÇA TOTAL</h3>
                        <p>
                            Uma empresa abafada em ordens judiciais dispersas gera pânico nos fornecedores e colaboradores, inviabilizando qualquer entrega nova ou venda relevante.
                        </p>
                    </div>
                </div>

                <div class="important-box">
                    <p>
                        📌 <strong>A Vantagem da RJ:</strong> A Recuperação Judicial (Lei nº 11.101/05) é extremamente transparente. É um processo ordenado, no qual a lei dá ao empresário uma "armadura" de pelo menos seis meses (Stay Period) para ele organizar a casa sem ameaças diárias de lacre.
                    </p>
                </div>

                <div class="text-center mt-lg">
                    <a
                        href="https://api.whatsapp.com/send/?phone=554391244440&text=Minha%20empresa%20precisa%20de%20urgência%20contra%20atos%20de%20falência"
                        class="btn btn-primary"
                        data-message="Minha empresa precisa de urgência contra atos de falência">BLINDAR O CAIXA DA EMPRESA AGORA</a
                    >
                </div>
            </div>
        </section>

        <!-- 5. POR QUE DEFESA ESPECIALIZADA -->
        <section class="section">
            <div class="container">
                <h2>Cuidado: Entrar com o Advogado Errado Pode Converter sua Empresa Sumariamente em Falência</h2>
                <p class="section-subtitle">
                    A Recuperação Judicial é o processo cível-empresarial mais complexo do Brasil. Exige contundência técnica.
                </p>

                <div class="comparison-grid">
                    <div class="comparison-col comparison-bad">
                        <h3>❌ ESCRITÓRIOS SEM EXPERIÊNCIA EM CRISE TRIBUTÁRIA E "R.J."</h3>
                        <ul>
                            <li>Elaboram o pedido principal com inconsistências, e o Juiz nem aceita o deferimento da R.J. (o que já causa colapso das ações).</li>
                            <li>Sem entendimento tributário severo: não consideram que a dívida fiscal do Estado precisará ser transacionada pesadamente à parte.</li>
                            <li>Constroem um Plano de Recuperação ilógico que a Assembléia veta prontamente.</li>
                            <li>Incapacidade extrema de persuasão entre Credores (Bancos e Sindicatos).</li>
                            <li>Tratam a operação como um processo normal cível. A empresa quebra no meio do caminho (Convolação em Falência).</li>
                        </ul>
                        <p class="comparison-result result-bad">
                            Resultado Final: Juiz e credores rejeitam o plano. Falência decretada.
                        </p>
                    </div>

                    <div class="comparison-col comparison-good">
                        <h3>✅ ATUAÇÃO DA GLAUCO RAMOS ADVOCACIA</h3>
                        <ul>
                            <li><strong>Análise Prévia de Viabilidade:</strong> Construímos laudos sólidos antes do ajuizamento, garantindo que o deferimento do processo seja uma certeza.</li>
                            <li><strong>Blindagem Integral:</strong> Aliamos Direito Societário e Tributário para salvar o seu CNPJ protegendo os CPFs dos fundadores.</li>
                            <li><strong>Formulação Cirúrgica:</strong> Prevemos cortes, deságios imensos, vendas de filiais (UPIS) e repactuações com até dezenas de anos nos planos.</li>
                            <li>Luta direta contra a Execução Tributária que ocorre por fora e que asfixia a empresa.</li>
                        </ul>
                        <p class="comparison-result result-good">
                            Resultado Final: Plano homologado, empresa blindada faturando com margens saudáveis, sem medo da porta fechada.
                        </p>
                    </div>
                </div>

                <div class="text-center mt-lg">
                    <a
                        href="https://api.whatsapp.com/send/?phone=554391244440&text=Quero%20uma%20análise%20sobre%20o%20risco%20de%20Falência%20no%20meu%20Negócio"
                        class="btn btn-primary"
                        data-message="Quero uma análise sobre o risco de Falência no meu Negócio">EM QUAL ETAPA MINHA EMPRESA ESTÁ? AGENDE REUNIÃO</a
                    >
                </div>
            </div>
        </section>

        <!-- 6. METODOLOGIA -->
        <section class="section section-alt">
            <div class="container">
                <h2>O Caminho Para o Ar Aliviado do "Plano Homologado"</h2>
                <p class="section-subtitle">As etapas oficiais da Lei de Recuperação Judicial e nossa condução ponta a ponta.</p>

                <div class="timeline">
                    <div class="timeline-item">
                        <div class="timeline-number">1</div>
                        <div class="timeline-content">
                            <h3>Diagnóstico e Ajuizamento do Pedido (Dia 0)</h3>
                            <p>
                                Construímos a fundamentação e a demonstração da crise com auditoria. Com as petições, protocolamos para garantir o deferimento inicial.
                            </p>
                        </div>
                    </div>

                    <div class="timeline-item">
                        <div class="timeline-number">2</div>
                        <div class="timeline-content">
                            <h3>Deferimento e Stay Period (O Fôlego Mágico)</h3>
                            <p>
                                Após o Juiz deferir o processoamento da RJ, há a chamada Fase de Blindagem. Estão suspensos leilões, execuções e bloqueios por no mínimo 180 dias.
                            </p>
                        </div>
                    </div>

                    <div class="timeline-item">
                        <div class="timeline-number">3</div>
                        <div class="timeline-content">
                            <h3>O Plano de Recuperação (As Regras do Deságio)</h3>
                            <p>
                                Auxiliados por nossa junta econômica, definimos a proposta legal (ex: Credor receberá X anos com X% de perdão da dívida e deságio, e carência de entrada).
                            </p>
                        </div>
                    </div>

                    <div class="timeline-item">
                        <div class="timeline-number">4</div>
                        <div class="timeline-content">
                            <h3>Assembleia Geral de Credores (AGC)</h3>
                            <p>
                                Representamos o seu CNPJ politicamente e juridicamente perante os votos dos bancos, fornecedores e ex-empregados. Negociação contínua pesada, garantindo aprovação das contas. 
                            </p>
                        </div>
                    </div>

                    <div class="timeline-item">
                        <div class="timeline-number">5</div>
                        <div class="timeline-content">
                            <h3>Homologação Pelo Juiz (Novação da Dívida)</h3>
                            <p>
                                A mágica acontece. O plano é Homologado, toda dor de cabeça e antigas dívidas são engolidas e "novadas" (substituídas) apenas pelas regras novas em que a empresa tem poder de pagar.
                            </p>
                        </div>
                    </div>
                </div>

                <div class="info-box">
                    <p>
                        💼 <strong>Venda de Ativos Limpos (UPI):</strong> Na nossa condução da RJ podemos prever a venda de imóveis comerciais ou filiais sem que os credores possam travar a venda, formando um caixa de excelência rápida e livre de passivos (Unidade Produtiva Isolada).
                    </p>
                </div>

                <div class="text-center mt-lg">
                    <a
                        href="https://api.whatsapp.com/send/?phone=554391244440&text=Gostaria%20de%20entender%20como%20o%20plano%20se%20aplicaria%20na%20prática"
                        class="btn btn-primary"
                        data-message="Gostaria de entender como o plano se aplicaria na prática">AVALIAR A ESTRUTURA PARA MINHA INDÚSTRIA/COMÉRCIO</a
                    >
                </div>
            </div>
        </section>

        <!-- 7. ÁREAS DE ATUAÇÃO / SERVIÇOS TÍPICOS -->
        <section class="section">
            <div class="container">
                <h2>Serviços Vinculados em Resgate de Crise de Empresa</h2>
                <p class="section-subtitle">Tudo o que envolve salvar um endividamento sistêmico</p>

                <div class="services-grid">
                    <div class="service-card">
                        <!-- Briefcase Icon -->
                        <svg class="service-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                            <rect x="2" y="7" width="20" height="14" rx="2" ry="2"></rect>
                            <path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"></path>
                        </svg>
                        <h3>Recuperação Judicial (Principal)</h3>
                        <p>
                            Defesa judicial robusta via processo de Recuperação de modo que a empresa continua sua operação reestruturando prazos e valores gigantes via juízo.
                        </p>
                    </div>

                    <div class="service-card">
                        <!-- Break Icon: Unlink -->
                        <svg class="service-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                            <path d="M18.36 6.64a9 9 0 1 1-12.73 0"></path>
                            <line x1="12" y1="2" x2="12" y2="12"></line>
                        </svg>
                        <h3>Recuperação Extrajudicial (RE)</h3>
                        <p>
                            Modelo menos custoso onde alinhavamos o perdão de juros privadamente com um "grupo seleto de bancões" e apenas solicitamos homologação judicial limpa.
                        </p>
                    </div>

                    <div class="service-card">
                        <!-- Chart Bar / Money -->
                        <svg class="service-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                            <line x1="12" y1="1" x2="12" y2="23"></line>
                            <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path>
                        </svg>
                        <h3>Transação Tributária (Débitos Fiscais da R.J.)</h3>
                        <p>
                            Os débitos tributários ficam fora da aprovação em Assembléia. Nosso lado de <strong>Tributarista Ex-procurador</strong> age aqui para colocar o Estado nas cordas com descontos monumentais através nos parcelamentos fiscais específicos de R.J.
                        </p>
                    </div>

                    <div class="service-card">
                        <!-- Merge / Network -->
                        <svg class="service-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                            <circle cx="18" cy="5" r="3"></circle>
                            <circle cx="6" cy="12" r="3"></circle>
                            <circle cx="18" cy="19" r="3"></circle>
                            <line x1="8.59" y1="13.51" x2="15.42" y2="17.49"></line>
                            <line x1="15.41" y1="6.51" x2="8.59" y2="10.49"></line>
                        </svg>
                        <h3>Defesa Contundente Contra Pedido De Falência</h3>
                        <p>
                            O fornecedor entrou com ação pedindo sua quebra pela porta dos fundos? Atuamos no contra-ataque neutralizando as ameaças de dissolução compulsória do faturamento.
                        </p>
                    </div>

                    <div class="service-card">
                        <!-- Default shield -->
                        <svg class="service-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                           <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
                        </svg>
                        <h3>Negociação Blindada Privada Coletiva</h3>
                        <p>
                            Acordos entre devedores que não dependem do foro e não chamam o status da "empresa estar em recuperação" quando não for a estratégia correta frente à credibilidade.
                        </p>
                    </div>

                    <div class="service-card">
                        <!-- File Text -->
                        <svg class="service-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
